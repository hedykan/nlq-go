# NLQ服务配置文件示例
# 复制此文件为 config.yaml 并填入真实配置

# 数据库配置
database:
  driver: mysql
  host: localhost
  port: 3306
  database: loloyal
  username: root
  password: root
  readonly: true  # 只读模式，推荐用于生产环境

# LLM配置
llm:
  provider: zhipuai
  model: glm-4-plus
  api_key: "${GLM_API_KEY}"  # 从环境变量读取，或直接填入API Key
  base_url: https://open.bigmodel.cn/api/paas/v4/
  max_retries: 3
  timeout: 30s

# 安全配置
security:
  mode: strict  # 严格模式：只允许SELECT语句
  check_comments: true  # 检查SQL注释注入
  check_semicolon: true  # 检查多语句执行

# 服务器配置
server:
  port: 8080
  host: "0.0.0.0"
  read_timeout: 30s
  write_timeout: 30s
  enable_cors: true
  query_timeout: 10s

# 日志配置
logging:
  level: info  # debug, info, warn, error
  format: json  # json, text
